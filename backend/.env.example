# Database
# For Supabase Pooler, add pgbouncer=true to avoid prepared statement errors.
DATABASE_URL="postgresql://postgres.xxxxx:<YOUR_DATABASE_PASSWORD>@aws-x-region.pooler.supabase.com:6543/postgres?pgbouncer=true"

# LLM API
# DeepSeek is OpenAI-compatible. You can also use the default OpenAI base URL.
OPENAI_API_KEY="your-llm-api-key"
OPENAI_BASE_URL="https://api.deepseek.com"
OPENAI_MODEL="deepseek-chat"
OPENAI_MAX_TOKENS=4000

# Server
PORT=3001
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"

# Rate limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=20
